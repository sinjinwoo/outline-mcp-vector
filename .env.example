# --- Embedding provider: gemini (default) | openai ---
EMBEDDING_PROVIDER=gemini

# Gemini (EMBEDDING_PROVIDER=gemini)
# Comma-separated API key pool — requests round-robin across these keys and
# auto-retry on the next key on 429 / transient errors.
GOOGLE_API_KEYS=key1,key2,key3
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=3072

# OpenAI (EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
# API key for Qdrant authentication.
# Set the same value in Qdrant (via QDRANT__SERVICE__API_KEY) and here.
# Leave blank to run without authentication (local dev only).
QDRANT_API_KEY=my_strong_secret_key

# --- Outline ---
OUTLINE_BASE_URL=https://your-outline-instance.example.com
OUTLINE_API_KEY=ol_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret set in Outline → Settings → Webhooks
OUTLINE_WEBHOOK_SECRET=your_webhook_secret_here

# --- MCP Server ---
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080

# --- Celery / Redis (webhook + sync task queue) ---
REDIS_URL=redis://redis:6379/1
# How often the beat scheduler enqueues an incremental sync, in seconds.
SYNC_INTERVAL_SECONDS=3600
