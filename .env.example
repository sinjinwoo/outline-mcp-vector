# ============================================================
# 필수 — Outline 관리자 화면에서만 발급되는 값이라 자동으로 가져올 방법이 없습니다.
# ============================================================

# Outline → Settings → API & Apps → New API key
OUTLINE_API_KEY=ol_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Outline → Settings → Webhooks → New webhook 등록 시 설정한 Secret
OUTLINE_WEBHOOK_SECRET=your_webhook_secret_here

# Outline의 공개 URL. 검색 결과의 문서 링크에 그대로 노출되므로 항상 외부에서
# 접근 가능한 주소여야 합니다 (Outline의 docker.env에 있는 URL과 동일한 값).
OUTLINE_BASE_URL=https://your-outline-instance.example.com

# Gemini API 키 — 쉼표로 여러 개 넣으면 라운드로빈 풀로 동작합니다.
# https://aistudio.google.com/apikey 에서 발급
GOOGLE_API_KEYS=key1,key2,key3

# Qdrant 인증 키. Qdrant 서버 자체가 쓰는 이름(service.api_key)을 그대로 씁니다
# (docker-compose.yml이 이 값을 Qdrant 컨테이너에도 그대로 전달합니다). 값 자체는
# 원하는 임의의 문자열로 정하면 됩니다.
QDRANT__SERVICE__API_KEY=my_strong_secret_key

# ============================================================
# 선택 — Outline과 같은 서버/Docker 네트워크에 배포한 경우에만 설정
# (자세한 내용은 README "Outline과 같은 호스트에 배포하는 경우" 참고)
# ============================================================

# Outline API를 내부망으로 직접 호출해 공개 URL 왕복을 생략합니다. 검색 결과의
# 문서 링크는 이 값과 무관하게 항상 OUTLINE_BASE_URL(공개 주소)을 쓰므로 켜도
# 링크가 깨지지 않습니다.
# OUTLINE_API_URL=http://outline:3000

# 출력 벡터 차원 (output_dimensionality). 모델은 gemini-embedding-2 고정이라
# 따로 고를 수 있는 옵션이 아니라서 뺐습니다.
# GEMINI_EMBEDDING_DIM=3072

# QDRANT_URL=http://localhost:6333
# Qdrant/Gemini 호출 타임아웃(초/밀리초). 응답 없이 멈추면 search_knowledge 요청이
# 무한정 걸려있게 되므로 기본값이 있지만, 네트워크 환경에 따라 조정하세요.
# QDRANT_TIMEOUT_SECONDS=10
# GEMINI_TIMEOUT_MS=30000

# MCP_HOST=0.0.0.0
# MCP_PORT=8080

# DNS rebinding 방지(Host/Origin 헤더 검증)를 켭니다. 배포 도메인을 쉼표로
# 나열하세요(리버스 프록시 뒤라면 프록시가 넘기는 Host 값 기준). 비워두면
# 검증이 꺼진 채로 기동됩니다 — 값을 채우기 전까지 이전과 동일하게 동작하지만,
# 프로덕션에서는 채우는 걸 권장합니다.
# MCP_ALLOWED_HOSTS=notionmcp.jwlabs.dedyn.io
# Origin 헤더가 없는 요청(curl, Claude Desktop 원격 커넥터 등)은 same-origin으로
# 간주되어 항상 통과합니다 — 이 목록은 브라우저에서 오는 요청만 걸러냅니다.
# MCP_ALLOWED_ORIGINS=https://notionmcp.jwlabs.dedyn.io

# MCP 서버 인증(Keycloak/OAuth)은 기본이 완전 개방(인증 없음)입니다. 켜려면
# MCP_OAUTH_ENABLED=true로 두고 아래 세 값을 전부 채우세요 — 이 서버는 자체
# 인가 서버가 아니라 리소스 서버 역할만 하므로, 별도로 이미 떠 있는 Keycloak
# realm이 필요합니다(참고용 docker-compose 예시는 docs/ 참고).
# MCP_OAUTH_ENABLED=true
# Keycloak realm의 issuer URL. 예: https://keycloak.example.com/realms/myrealm
# MCP_OAUTH_ISSUER_URL=https://keycloak.example.com/realms/myrealm
# 이 MCP 서버 자신의 외부 접근 URL, /mcp 경로까지 포함 (Protected Resource Metadata에 노출됨)
# MCP_OAUTH_RESOURCE_URL=https://mcp.your-domain.com/mcp
# 토큰의 aud 클레임과 대조할 값. Keycloak 클라이언트에 audience 매퍼를 설정해야
# 토큰에 이 값이 실립니다.
# MCP_OAUTH_AUDIENCE=outline-mcp
# JWKS 엔드포인트. 비워두면 Keycloak 기본 경로
# ({issuer}/protocol/openid-connect/certs)를 사용합니다.
# MCP_OAUTH_JWKS_URL=https://keycloak.example.com/realms/myrealm/protocol/openid-connect/certs

# Outline이 이미 띄운 Redis를 별도 논리 DB로 재사용합니다 — 이 스택에서 별도
# Redis 컨테이너를 만들지 않습니다.
# REDIS_URL=redis://redis:6379/1

# Beat가 증분 동기화를 큐잉하는 주기(초).
# SYNC_INTERVAL_SECONDS=3600
